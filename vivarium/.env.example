# ============================================================
# Vivarium Monitoring Pipeline — Environment Variables
# Copy this file to .env and fill in real values.
# NEVER commit the actual .env file to version control.
# ============================================================

# --- API Authentication ---
API_KEY=my-vivarium-secret-key-123
# --- PostgreSQL ---
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=Mydatabase
POSTGRES_USER=vivarium
POSTGRES_PASSWORD=newpassword

# --- Telegram Notifier ---
TELEGRAM_BOT_TOKEN=123456:ABC-DEF...
TELEGRAM_CHAT_ID=your-chat-id

# --- AWS S3 (only if storage.image_store = s3) ---
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1
S3_BUCKET=

# --- Google Cloud Storage (only if storage.image_store = gcs) ---
GOOGLE_APPLICATION_CREDENTIALS=./service-account.json

# --- Loki Logging (only if logging.sink = loki) ---
LOKI_URL=http://localhost:3100
